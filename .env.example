# llvm-mingw Docker build defaults
# Copy to .env.local or pass as make args to override.

# Go versions to build (space-separated)
# major.minor only (latest patch auto-resolved from go.dev)
GO_VERSIONS=1.24 1.25 1.26

# llvm-mingw release tags (space-separated)
# Latest: 20260616 (LLVM 22.1.8)
LLVM_VERSIONS=20260616 20260519 20260421 20260324 20260224 20251216 20251104 20250910 20250709 20250514 20250417

# Container registry (for push targets)
REGISTRY=ghcr.io/aldok10

# Image name
IMAGE_NAME=golang-llvm-mingw-compiler
